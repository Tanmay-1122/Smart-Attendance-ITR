# Smart Attendance Environment Variables
# Copy this to .env/.env and fill in your actual values

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_GROUP_ID=your_group_id_here

# Google AI (Gemini)
GOOGLE_AI_KEY=your_google_ai_key_here

# Flask Secret Key (generate a random one)
SECRET_KEY=change_this_to_a_random_string

# Database (optional, defaults to sqlite)
# DATABASE_URL=postgresql://user:pass@host/dbname

# Face API URL (Hugging Face Space)
HF_FACE_API_URL=https://your-username-your-space.hf.space
